{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/register-form", "destination": "/index.html" },
    { "source": "/esct_presentation", "destination": "/index.html" },
    { "source": "/esct_presentation.html", "destination": "/index.html" },
    { "source": "/verum-landing", "destination": "/index.html" },
    { "source": "/verum-landing.html", "destination": "/index.html" },
    { "source": "/bode-coin-landing", "destination": "/index.html" },
    { "source": "/bode-coin-landing.html", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Content-Type", "value": "image/png" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
